#!/usr/bin/env bash
# scripts/indexer - Cross-chain indexer CLI for Pharos
#
# Usage:
#   bash scripts/indexer balance <address> [chain]
#   bash scripts/indexer tx <tx-hash>
#   bash scripts/indexer portfolio <address> [chain]
#   bash scripts/indexer label <address>
#   bash scripts/indexer verify <address> [chain]
#
# Prerequisites: jq, curl, cast (from Foundry)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(dirname "$SCRIPT_DIR")"
NETWORKS_FILE="$ROOT_DIR/assets/networks.json"
TOKENS_FILE="$ROOT_DIR/assets/tokens.json"

# --- resolve jq (must work even if not on PATH) ---
# Look for jq in order: $JQ env, then PATH, then project root / scripts dir.
if [ -n "${JQ:-}" ] && [ -x "$JQ" ]; then
    : # use provided
elif command -v jq >/dev/null 2>&1; then
    JQ="$(command -v jq)"
else
    for cand in "$ROOT_DIR/jq" "$ROOT_DIR/jq.exe" "$SCRIPT_DIR/jq" "$SCRIPT_DIR/jq.exe"; do
        if [ -x "$cand" ]; then JQ="$cand"; break; fi
    done
fi
[ -z "${JQ:-}" ] && { echo -e "\033[0;31mERROR:\033[0m jq not found. Install: apt-get install jq / brew install jq / winget install jqlang.jq" >&2; exit 1; }

# On Git Bash / WSL, jq.exe is a Windows binary that needs Windows-style paths.
# Auto-detect: if $JQ ends in .exe, convert paths. Try cygpath first,
# fall back to manual /mnt/c/ -> C:\ conversion (WSL).
if [[ "$JQ" == *.exe ]]; then
    if command -v cygpath >/dev/null 2>&1; then
        NETWORKS_FILE="$(cygpath -w "$ROOT_DIR/assets/networks.json")"
        TOKENS_FILE="$(cygpath -w "$ROOT_DIR/assets/tokens.json")"
    else
        # Manual /mnt/<drive>/<path> -> <Drive>:\<path> for WSL
        for var in NETWORKS_FILE TOKENS_FILE; do
            val="${!var}"
            if [[ "$val" == /mnt/* ]]; then
                drive="${val:5:1}"
                rest="${val:6}"
                rest="${rest//\//\\}"
                eval "${var}=\"${drive^^}:${rest}\""
            fi
        done
    fi
fi

# --- resolve python (Windows often has `python` not `python3`) ---
# On Windows the Microsoft Store hijacks `python3` as a redirector that prints
# "Python was not found". Detect once: prefer python3 (Linux/Mac), else python.
if command -v python3 >/dev/null 2>&1 && python3 --version >/dev/null 2>&1; then
    PY="$(command -v python3)"
elif command -v python >/dev/null 2>&1 && python --version >/dev/null 2>&1; then
    PY="$(command -v python)"
else
    echo -e "\033[0;31mERROR:\033[0m python not found. Install Python 3 and ensure \`python\` or \`python3\` is on PATH." >&2
    exit 1
fi

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m'

# --- globals ---

JSON_OUTPUT=false
QUIET_MODE=false
USD_MODE=false
CSV_MODE=false
ALL_CHAINS=false
PRICE_CACHE_FILE="/tmp/pharos_indexer_prices"

# --- helpers ---

die() { echo -e "${RED}ERROR:${NC} $*" >&2; exit 1; }
info() { echo -e "${CYAN}->${NC} $*"; }
total_chains() { "$JQ" '.networks | length' "$NETWORKS_FILE"; }
scope_str() { if [ "$ALL_CHAINS" = "true" ]; then echo "all $(total_chains) chains"; else echo "top 15 of $(total_chains) chains (pass --all for all)"; fi; }

get_rpcs() {
    if [ "$ALL_CHAINS" = "true" ]; then
        "$JQ" -r '.networks[] | select(.rpcUrl != null and .rpcUrl != "") | "\(.name)|\(.rpcUrl)|\(.chainId)|\(.nativeToken)|\(.type)"' "$NETWORKS_FILE"
    else
        "$JQ" -r '.networks[0:15][] | select(.rpcUrl != null and .rpcUrl != "") | "\(.name)|\(.rpcUrl)|\(.chainId)|\(.nativeToken)|\(.type)"' "$NETWORKS_FILE"
    fi
}

get_explorers() {
    if [ "$ALL_CHAINS" = "true" ]; then
        "$JQ" -r '.networks[] | select(.explorerApiUrl != null and .explorerApiUrl != "") | "\(.name)|\(.explorerApiUrl)|\(.explorerUrl)|\(.type)"' "$NETWORKS_FILE"
    else
        "$JQ" -r '.networks[0:15][] | select(.explorerApiUrl != null and .explorerApiUrl != "") | "\(.name)|\(.explorerApiUrl)|\(.explorerUrl)|\(.type)"' "$NETWORKS_FILE"
    fi
}

# USD price conversion via CoinGecko + fallback
get_usd_price() {
    local symbol="$1"
    local cg_id
    cg_id=$("$JQ" -r --arg sym "$symbol" '.tokens[$sym].cg_id // "null"' "$ROOT_DIR/assets/priceFeeds.json" 2>/dev/null)

    if [ "$cg_id" = "null" ] || [ -z "$cg_id" ]; then echo "N/A"; return; fi

    # Check cache (valid 5 min)
    if [ -f "$PRICE_CACHE_FILE" ]; then
        local cache_val cache_time
        cache_val=$(grep "^${symbol}=" "$PRICE_CACHE_FILE" 2>/dev/null | cut -d= -f2 | cut -d'|' -f1) || true
        cache_time=$(grep "^${symbol}=" "$PRICE_CACHE_FILE" 2>/dev/null | cut -d= -f2 | cut -d'|' -f2) || true
        cache_val="${cache_val:-}"
        cache_time="${cache_time:-0}"
        local now; now=$(date +%s)
        if [ -n "$cache_val" ] && [ "$now" -lt "$((cache_time + 300))" ] 2>/dev/null; then
            echo "$cache_val"; return
        fi
    fi

    # Fetch live from CoinGecko
    local price resp
    resp=$(curl -s --connect-timeout 8 --max-time 12 \
        "https://api.coingecko.com/api/v3/simple/price?ids=${cg_id}&vs_currencies=usd" 2>/dev/null) || true
    price=$(echo "$resp" | "$JQ" -r ".[\"${cg_id}\"].usd // \"N/A\"" 2>/dev/null)

    if [ "$price" != "N/A" ] && [ "$price" != "null" ] && [ -n "$price" ]; then
        echo "${symbol}=${price}|$(date +%s)" >> "$PRICE_CACHE_FILE"
        echo "$price"; return
    fi
    echo "N/A"
}

format_balance() {
    # Takes wei hex, returns ether string
    local wei_hex="$1"
    if command -v cast >/dev/null 2>&1; then
        echo "$wei_hex" | xargs -I{} cast --from-wei {} 2>/dev/null || echo "0"
    else
        # Fallback: use bc or python
        $PY -c "print(int('$wei_hex', 16) / 1e18)" 2>/dev/null || echo "0"
    fi
}

# --- balance ---

cmd_balance() {
    local addr="${1:-}"
    local filter_chain="${2:-}"

    if [ -z "$addr" ]; then
        echo "Usage: $0 balance <address> [chain]"
        echo "Example: $0 balance 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045"
        exit 1
    fi

    if [ "$JSON_OUTPUT" != "true" ]; then
        echo ""
        echo "========================================================="
        echo "|  Multi-Chain Balance                                    |"
        echo "+---------------------------------------------------------+"
        printf "|  Address: %-42s  |\n" "${addr:0:42}"
        echo "========================================================="
        echo "  Scope: $(scope_str)"
        echo ""
    fi

    local found=0
    local json_results="["
    local first_json=true

    while IFS='|' read -r chain rpc chainId nativeToken ctype; do
        if [ -n "$filter_chain" ] && [ "$chain" != "$filter_chain" ]; then continue; fi

        local result
        case "$ctype" in
            solana)
                local sol_resp
                sol_resp=$(curl -s -X POST -H "Content-Type: application/json" \
                    --data "{\"jsonrpc\":\"2.0\",\"method\":\"getBalance\",\"params\":[\"$addr\"],\"id\":1}" \
                    --connect-timeout 10 --max-time 15 "$rpc" 2>/dev/null) || true
                local sol_value
                sol_value=$(echo "$sol_resp" | "$JQ" -r '.result.value // -1' 2>/dev/null)
                if [ "$sol_value" != "-1" ] && [ -n "$sol_value" ]; then
                    result=$($PY -c "print(round(int($sol_value) / 1e9, 6))" 2>/dev/null || echo "0")
                else result=""; fi
                ;;
            bitcoin)
                local btc_resp
                btc_resp=$(curl -s "${rpc}/${addr}?confirmations=0" --connect-timeout 10 2>/dev/null) || true
                if [ -n "$btc_resp" ] && [ "$btc_resp" != "0" ] 2>/dev/null; then
                    result=$($PY -c "print(int($btc_resp) / 1e8)" 2>/dev/null || echo "0")
                else result="0"; fi
                ;;
            tron)
                local tron_resp
                tron_resp=$(curl -s "${rpc}?address=${addr}" --connect-timeout 10 2>/dev/null) || true
                local tron_bal
                tron_bal=$(echo "$tron_resp" | "$JQ" -r '.balance // 0' 2>/dev/null)
                result=$($PY -c "print(int($tron_bal) / 1e6)" 2>/dev/null || echo "0")
                ;;
            near)
                local near_resp
                near_resp=$(curl -s "${rpc}/${addr}" --connect-timeout 10 2>/dev/null) || true
                local near_bal
                near_bal=$(echo "$near_resp" | "$JQ" -r '.account[0].amount // 0' 2>/dev/null)
                result=$($PY -c "print(int('$near_bal') / 1e24)" 2>/dev/null || echo "0")
                ;;
            cosmos)
                local cosmos_resp
                cosmos_resp=$(curl -s "${rpc}/${addr}" --connect-timeout 10 2>/dev/null) || true
                local cosmos_bal
                cosmos_bal=$(echo "$cosmos_resp" | "$JQ" -r '.balances[] | select(.denom==\"uatom\") | .amount // 0' 2>/dev/null)
                result=$($PY -c "print(int('$cosmos_bal') / 1e6)" 2>/dev/null || echo "0")
                ;;
            dogecoin)
                local doge_resp
                doge_resp=$(curl -s "${rpc}/${addr}" --connect-timeout 10 2>/dev/null) || true
                local doge_bal
                doge_bal=$(echo "$doge_resp" | "$JQ" -r '.balance // 0' 2>/dev/null)
                result=$($PY -c "print(int('$doge_bal') / 1e8)" 2>/dev/null || echo "0")
                ;;
            polkadot)
                local dot_resp
                dot_resp=$(curl -s -X POST "${rpc}" -H 'Content-Type: application/json' \
                    -d "{\"address\":\"${addr}\"}" --connect-timeout 10 2>/dev/null) || true
                local dot_bal
                dot_bal=$(echo "$dot_resp" | "$JQ" -r '.data.balance // 0' 2>/dev/null)
                result=$($PY -c "print(int('$dot_bal') / 1e10)" 2>/dev/null || echo "0")
                ;;
            ton)
                local ton_resp
                ton_resp=$(curl -s "${rpc}?address=${addr}" --connect-timeout 10 2>/dev/null) || true
                local ton_bal
                ton_bal=$(echo "$ton_resp" | "$JQ" -r '.result.balance // 0' 2>/dev/null)
                result=$($PY -c "print(int('$ton_bal') / 1e9)" 2>/dev/null || echo "0")
                ;;
            *)
                if command -v cast >/dev/null 2>&1; then
                    result=$(cast balance "$addr" --rpc-url "$rpc" --ether 2>/dev/null) || true
                else
                    local resp
                    resp=$(curl -s -X POST -H "Content-Type: application/json" \
                        --data "{\"jsonrpc\":\"2.0\",\"method\":\"eth_getBalance\",\"params\":[\"$addr\",\"latest\"],\"id\":1}" \
                        "$rpc" 2>/dev/null) || true
                    local wei_hex
                    wei_hex=$(echo "$resp" | "$JQ" -r '.result // "0x0"' 2>/dev/null)
                    result=$($PY -c "print(int('$wei_hex', 16) / 1e18)" 2>/dev/null || echo "0")
                fi
                ;;
        esac

        # USD conversion
        local usd_str=""
        if [ "$USD_MODE" = "true" ] && [ -n "$result" ] && [ "$result" != "" ]; then
            local usd_price
            usd_price=$(get_usd_price "$nativeToken")
            if [ "$usd_price" != "N/A" ] && [ -n "$usd_price" ]; then
                local usd_val
                usd_val=$($PY -c "print(round(float($result) * float($usd_price), 2))" 2>/dev/null || echo "N/A")
                usd_str=$(printf ' ($%.2f)' "$usd_val")
            fi
        fi

        if [ -n "$result" ] && [ "$result" != "" ]; then
            if [ "$JSON_OUTPUT" = "true" ]; then
                [ "$first_json" = "false" ] && json_results+=","
                first_json=false
                local status="online"
                json_results+="{\"chain\":\"$chain\",\"chainId\":$chainId,\"balance\":\"$result\",\"symbol\":\"$nativeToken\",\"status\":\"$status\"}"
                if [ "$USD_MODE" = "true" ] && [ -n "$usd_str" ]; then
                    json_results="${json_results::-1},\"usd\":\"${usd_str//[()\$ ]/}\"}"
                fi
            else
                printf "  %-15s %12s %s%s\n" "$chain" "$result" "$nativeToken" "$usd_str"
            fi
            found=$((found + 1))
        elif [ "$result" = "" ]; then
            if [ "$JSON_OUTPUT" = "true" ]; then
                [ "$first_json" = "false" ] && json_results+=","
                first_json=false
                json_results+="{\"chain\":\"$chain\",\"chainId\":$chainId,\"balance\":\"0\",\"symbol\":\"$nativeToken\",\"status\":\"offline\"}"
            else
                printf '%s' "  ${RED}${chain}${NC}"; printf '%12s %s\n' "--" "$nativeToken"
            fi
        fi
    done < <(get_rpcs)

    json_results+="]"

    if [ "$JSON_OUTPUT" = "true" ]; then
        echo "$json_results" | "$JQ" .
    else
        echo ""
        if [ $found -eq 0 ]; then
            echo "  No balance found on any chain for this address."
        fi
    fi
}

# --- tx lookup ---

# eth_getTransactionByHash on a free public RPC. Returns:
#   "chain_id|chain_name|block_hex|from_addr|to_addr|value_hex|nonce_hex|gas_hex|input_hex"  on match
#   "" on miss / network error
rpc_get_tx() {
    local rpc="$1" txhash="$2" chain_id="$3" chain_name="$4"
    local resp
    resp=$(curl -s -X POST -H "Content-Type: application/json" \
        --data "{\"jsonrpc\":\"2.0\",\"method\":\"eth_getTransactionByHash\",\"params\":[\"$txhash\"],\"id\":1}" \
        --connect-timeout 8 --max-time 12 "$rpc" 2>/dev/null) || true
    # safe extraction: only access fields when .result is an object, otherwise null
    local result_type
    result_type=$(echo "$resp" | "$JQ" -r '.result | type' 2>/dev/null)
    if [ "$result_type" != "object" ]; then return 1; fi
    local block_hash
    block_hash=$(echo "$resp" | "$JQ" -r '.result.blockHash // ""' 2>/dev/null)
    [ -z "$block_hash" ] || [ "$block_hash" = "null" ] && return 1
    local block_num from_addr to_addr value_hex
    block_num=$(echo "$resp" | "$JQ" -r '.result.blockNumber // "?"' 2>/dev/null)
    from_addr=$(echo "$resp" | "$JQ" -r '.result.from // "?"' 2>/dev/null)
    to_addr=$(echo "$resp" | "$JQ" -r '.result.to // "?"' 2>/dev/null)
    value_hex=$(echo "$resp" | "$JQ" -r '.result.value // "0x0"' 2>/dev/null)
    echo "${chain_id}|${chain_name}|${block_num}|${from_addr}|${to_addr}|${value_hex}"
}

cmd_tx() {
    local txhash="${1:-}"

    if [ -z "$txhash" ]; then
        echo "Usage: $0 tx <tx-hash>"
        echo "Example: $0 tx 0x33a1600e7caccbba921526c3fd9dc23ea5e836f7c7f77f89c0a7ef3b55fe1906"
        exit 1
    fi

    echo ""
    echo "========================================================="
    echo "|  Cross-Chain Tx Lookup                                  |"
    echo "+---------------------------------------------------------+"
    printf "|  Tx: %-46s      |\n" "${txhash:0:46}"
    echo "========================================================="
    echo ""

    local found=0
    local scope_note=""
    [ "$ALL_CHAINS" = "true" ] && scope_note=" (all chains)" || scope_note=" (top 15 — pass --all for all)"
    printf "  Scope:%s\n" "$scope_note"

    # Direct RPC eth_getTransactionByHash on every EVM chain. Free, no API key,
    # no rate limit on public nodes, and works even when the explorer API is
    # down or has deprecated (Etherscan V1 -> V2 migration). Skips non-EVM
    # (Solana, Near) and chains without an RPC.
    while IFS='|' read -r chain rpc chainId nativeToken ctype; do
        [ -z "$rpc" ] && continue
        local line
        line=$(rpc_get_tx "$rpc" "$txhash" "$chainId" "$chain" || true)
        if [ -n "$line" ]; then
            local f_chainId f_chain f_block f_from f_to f_value
            IFS='|' read -r f_chainId f_chain f_block f_from f_to f_value <<< "$line"
            # value in ether (for native only, may be 0 for ERC20 tx)
            local value_eth
            value_eth=$(printf "%d" "${f_value}" 2>/dev/null | awk '{printf "%.6f", $1/1e18}' 2>/dev/null || echo "?")
            printf '%s\n' "  ${GREEN}[OK] Found on $f_chain${NC} (chainId $f_chainId) -- block $f_block"
            printf '%s\n' "    From:  $f_from"
            printf '%s\n' "    To:    $f_to"
            printf '%s\n' "    Value: $value_eth $nativeToken"
            # Try to construct an explorer link if we have a known explorer for this chain
            local exp
            exp=$(get_explorers | awk -F'|' -v c="$f_chain" '$1==c {print $3; exit}')
            if [ -n "$exp" ]; then
                # strip trailing slash to avoid double-slash in URL
                exp="${exp%/}"
                printf '%s\n' "    Explorer: ${exp}/tx/${txhash}"
            fi
            found=$((found + 1))
            break
        fi
    done < <(get_rpcs)

    if [ $found -eq 0 ]; then
        echo "  Transaction not found on any indexed EVM chain."
        printf '%s\n' "  It may still be pending, on a non-EVM chain (Solana/Near), or on a chain not in networks.json"
    fi
    echo ""
}

# --- portfolio ---

cmd_portfolio() {
    local addr="${1:-}"

    if [ -z "$addr" ]; then
        echo "Usage: $0 portfolio <address>"
        echo "Example: $0 portfolio 0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266"
        exit 1
    fi

    echo ""
    echo "========================================================="
    echo "|  Portfolio Overview                                     |"
    echo "+---------------------------------------------------------+"
    printf "|  Address: %-42s  |\n" "${addr:0:42}"
    echo "========================================================="
    echo ""

    printf "  %-14s %-8s %-16s %s\n" "Chain" "Token" "Balance" ""

    while IFS='|' read -r chain rpc chainId nativeToken ctype; do
        # Native balance
        local native_bal=""
        if command -v cast >/dev/null 2>&1; then
            native_bal=$(cast balance "$addr" --rpc-url "$rpc" --ether 2>/dev/null) || native_bal=""
        else
            local resp
            resp=$(curl -s -X POST -H "Content-Type: application/json" \
                --data "{\"jsonrpc\":\"2.0\",\"method\":\"eth_getBalance\",\"params\":[\"$addr\",\"latest\"],\"id\":1}" \
                "$rpc" 2>/dev/null) || true
            local wei_hex
            wei_hex=$(echo "$resp" | "$JQ" -r '.result // "0x0"' 2>/dev/null)
            native_bal=$($PY -c "print(round(int('$wei_hex', 16) / 1e18, 4))" 2>/dev/null || echo "")
        fi
        if [ -n "$native_bal" ] && [ "$native_bal" != "0" ] && [ "$native_bal" != "0.0" ]; then
            printf "  %-14s %-8s %16s\n" "$chain" "$nativeToken" "$native_bal"
        fi

        # ERC-20 tokens (from tokens.json)
        local tokens
        tokens=$("$JQ" -r --arg ch "$chain" '.[$ch] // [] | .[] | "\(.symbol)|\(.address)|\(.decimals)"' "$TOKENS_FILE" 2>/dev/null) || true
        if [ -n "$tokens" ]; then
            while IFS='|' read -r symbol tokenAddr decimals; do
                [ -z "$symbol" ] && continue
                local raw
                if command -v cast >/dev/null 2>&1; then
                    raw=$(cast call "$tokenAddr" "balanceOf(address)(uint256)" "$addr" --rpc-url "$rpc" 2>/dev/null) || raw="0x0"
                else
                    raw="0x0"
                fi
                local bal
                bal=$($PY -c "print(round(int('$raw', 16) / 10**$decimals, 4))" 2>/dev/null || echo "0")
                if [ "$bal" != "0" ] && [ "$bal" != "0.0" ]; then
                    printf "  %-14s %-8s %16s\n" "$chain" "$symbol" "$bal"
                fi
            done <<< "$tokens"
        fi
    done < <(get_rpcs)

    echo ""
}

# --- label ---

cmd_label() {
    local addr="${1:-}"

    if [ -z "$addr" ]; then
        echo "Usage: $0 label <address>"
        echo "Example: $0 label 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045"
        exit 1
    fi

    echo ""
    echo "========================================================="
    echo "|  Address Label                                          |"
    echo "+---------------------------------------------------------+"
    printf "|  Address: %-42s  |\n" "${addr:0:42}"
    echo "========================================================="
    echo ""

    local found=0
    while IFS='|' read -r chain apiUrl explorerUrl ctype; do
        # Pharos chains: SocialScan social graph
        if [ "$ctype" = "pharos" ]; then
            local resp
            resp=$(curl -s "${apiUrl}/social/label/${addr}" 2>/dev/null) || true
            local label
            label=$(echo "$resp" | "$JQ" -r '.label // empty' 2>/dev/null)
            if [ -n "$label" ]; then
                local cat
                cat=$(echo "$resp" | "$JQ" -r '.category // ""' 2>/dev/null)
                echo -e "  ${GREEN}${label}${NC} [${cat}] - ${chain} (PharosScan social)"
                found=$((found + 1))
            fi
        # Etherscan-compatible chains: check if verified contract has a name
        elif [ "$ctype" = "etherscan" ]; then
            local resp
            resp=$(curl -s "${apiUrl}?module=contract&action=getsourcecode&address=${addr}" 2>/dev/null) || true
            local contractName
            contractName=$(echo "$resp" | "$JQ" -r '.result[0].ContractName // empty' 2>/dev/null)
            if [ -n "$contractName" ]; then
                echo -e "  ${GREEN}${contractName}${NC} [verified contract] - ${chain} (${ctype})"
                found=$((found + 1))
            fi
        fi
    done < <(get_explorers)

    if [ $found -eq 0 ]; then
        echo "  No label found on any indexed chain."
    fi
    echo ""
}

# --- verify ---

cmd_verify() {
    local addr="${1:-}"

    if [ -z "$addr" ]; then
        echo "Usage: $0 verify <contract-address>"
        echo "Example: $0 verify 0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512"
        exit 1
    fi

    echo ""
    echo "========================================================="
    echo "|  Contract Verification                                  |"
    echo "+---------------------------------------------------------+"
    printf "|  Address: %-42s  |\n" "${addr:0:42}"
    echo "========================================================="
    echo ""

    local found=0
    while IFS='|' read -r chain apiUrl explorerUrl ctype; do
        local resp
        if [ "$ctype" = "pharos" ] || [ "$ctype" = "etherscan" ] || [ "$ctype" = "blockscout" ]; then
            resp=$(curl -s "${apiUrl}?module=contract&action=getsourcecode&address=${addr}" 2>/dev/null) || true
        elif [ "$ctype" = "zksync" ]; then
            resp=$(curl -s "${apiUrl}?module=contract&action=getsourcecode&address=${addr}" 2>/dev/null) || true
        else
            continue
        fi
        local verified
        verified=$(echo "$resp" | "$JQ" -r '.result[0].SourceCode // empty' 2>/dev/null)
        if [ -n "$verified" ] && [ "$verified" != "null" ] && [ "$verified" != "" ]; then
            echo -e "  ${GREEN}[OK] Verified on $chain${NC}"
            echo "    View source: ${explorerUrl}/address/${addr}#code"
            found=$((found + 1))
        fi
    done < <(get_explorers)

    if [ $found -eq 0 ]; then
        echo "  Contract not verified on any indexed chain."
    fi
    echo ""
}

# --- health ---

cmd_health() {
    local filter_chain="${1:-}"

    if [ "$JSON_OUTPUT" != "true" ]; then
        echo ""
        echo "========================================================="
        echo "|  RPC Health Check                                       |"
        echo "========================================================="
        echo "  Scope: $(scope_str)"
        echo ""
        printf "  %-18s %6s %8s %s\n" "Chain" "ChainID" "Status" "Block"
    fi

    local results_json="["
    local first=true

    while IFS='|' read -r chain rpc chainId nativeToken ctype; do
        if [ -n "$filter_chain" ] && [ "$chain" != "$filter_chain" ]; then continue; fi

        local resp block_num status
        resp=$(curl -s -X POST -H "Content-Type: application/json" \
            --data '{"jsonrpc":"2.0","method":"eth_blockNumber","params":[],"id":1}' \
            --connect-timeout 5 --max-time 10 "$rpc" 2>/dev/null) || true
        block_num=$(echo "$resp" | "$JQ" -r '.result // "0x0"' 2>/dev/null)
        
        if [ -n "$block_num" ] && [ "$block_num" != "0x0" ] && [ "$block_num" != "null" ]; then
            local dec_block
            dec_block=$(printf "%d" "$block_num" 2>/dev/null || echo "?")
            status="LIVE"
        else
            dec_block="-"
            status="DOWN"
        fi

        if [ "$JSON_OUTPUT" = "true" ]; then
            [ "$first" = "false" ] && results_json+=","
            first=false
            results_json+="{\"chain\":\"$chain\",\"chainId\":$chainId,\"status\":\"$status\",\"block\":\"$dec_block\",\"rpc\":\"$rpc\"}"
        else
            if [ "$status" = "LIVE" ]; then
                printf "  ${GREEN}%-18s${NC} %6s %8s %s\n" "$chain" "$chainId" "[OK] LIVE" "$dec_block"
            else
                printf "  ${RED}%-18s${NC} %6s %8s %s\n" "$chain" "$chainId" "[FAIL] DOWN" "$dec_block"
            fi
        fi
    done < <(get_rpcs)

    results_json+="]"
    
    if [ "$JSON_OUTPUT" = "true" ]; then
        echo "$results_json" | "$JQ" .
    else
        echo ""
    fi
}

# --- gas ---

cmd_gas() {
    local filter_chain="${1:-}"

    if [ "$JSON_OUTPUT" != "true" ]; then
        echo ""
        echo "========================================================="
        echo "|  Cross-Chain Gas Prices                                 |"
        echo "========================================================="
        echo ""
        printf "  %-18s %8s %14s %s\n" "Chain" "ChainID" "Gas (gwei)" ""
    fi

    local json_results="["
    local first_json=true

    while IFS='|' read -r chain rpc chainId nativeToken ctype; do
        if [ -n "$filter_chain" ] && [ "$chain" != "$filter_chain" ]; then continue; fi

        local resp gas_hex gas_gwei
        resp=$(curl -s -X POST -H "Content-Type: application/json" \
            --data '{"jsonrpc":"2.0","method":"eth_gasPrice","params":[],"id":1}' \
            --connect-timeout 5 --max-time 10 "$rpc" 2>/dev/null) || true
        gas_hex=$(echo "$resp" | "$JQ" -r '.result // "0x0"' 2>/dev/null)
        
        if [ -n "$gas_hex" ] && [ "$gas_hex" != "0x0" ] && [ "$gas_hex" != "null" ]; then
            gas_gwei=$($PY -c "print(round(int('$gas_hex', 16) / 1e9, 2))" 2>/dev/null || echo "?")
        else
            gas_gwei="DOWN"
        fi

        if [ "$JSON_OUTPUT" = "true" ]; then
            [ "$first_json" = "false" ] && json_results+=","
            first_json=false
            json_results+="{\"chain\":\"$chain\",\"chainId\":$chainId,\"gasGwei\":\"$gas_gwei\"}"
        else
            if [ "$gas_gwei" != "DOWN" ]; then
                printf "  %-18s %8s %10s gwei\n" "$chain" "$chainId" "$gas_gwei"
            else
                printf "  %-18s %8s %10s ${RED}DOWN${NC}\n" "$chain" "$chainId" "--"
            fi
        fi
    done < <(get_rpcs)

    json_results+="]"

    if [ "$JSON_OUTPUT" = "true" ]; then
        echo "$json_results" | "$JQ" .
    else
        echo ""
    fi
}

# --- top ---

cmd_top() {
    local addr="${1:-}"
    local token_symbol="${2:-USDC}"

    if [ -z "$addr" ]; then
        echo "Usage: $0 top <address> [token-symbol]"
        echo "Example: $0 top 0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266 USDC"
        echo "         $0 top 0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266 WETH"
        exit 1
    fi

    if [ "$JSON_OUTPUT" != "true" ]; then
        echo ""
        echo "========================================================="
        echo "|  Top Chains by $token_symbol Balance                    |"
        echo "+---------------------------------------------------------+"
        printf "|  Address: %-42s  |\n" "${addr:0:42}"
        echo "========================================================="
        echo ""
        printf "  %-18s %16s %s\n" "Chain" "Balance" ""
    fi

    # Collect all results, then sort
    local tmpfile
    tmpfile=$(mktemp)

    while IFS='|' read -r chain rpc chainId nativeToken ctype; do
        # Find the token address for this chain
        local token_addr decimals
        token_addr=$("$JQ" -r --arg ch "$chain" --arg sym "$token_symbol" \
            '.[$ch] // [] | .[] | select(.symbol == $sym) | .address' "$TOKENS_FILE" 2>/dev/null | head -1)
        decimals=$("$JQ" -r --arg ch "$chain" --arg sym "$token_symbol" \
            '.[$ch] // [] | .[] | select(.symbol == $sym) | .decimals' "$TOKENS_FILE" 2>/dev/null | head -1)

        if [ -z "$token_addr" ] || [ "$token_addr" = "null" ]; then
            continue
        fi

        local raw bal
        if command -v cast >/dev/null 2>&1; then
            raw=$(cast call "$token_addr" "balanceOf(address)(uint256)" "$addr" --rpc-url "$rpc" 2>/dev/null) || raw="0x0"
        else
            raw="0x0"
        fi
        bal=$($PY -c "print(round(int('$raw', 16) / 10**$decimals, 4))" 2>/dev/null || echo "0")
        echo "$bal|$chain|$chainId" >> "$tmpfile"
    done < <(get_rpcs)

    local json_results="["
    local first_json=true
    local rank=0

    while IFS='|' read -r bal_val bchain bchainId; do
        rank=$((rank + 1))
        if [ "$JSON_OUTPUT" = "true" ]; then
            [ "$first_json" = "false" ] && json_results+=","
            first_json=false
            json_results+="{\"rank\":$rank,\"chain\":\"$bchain\",\"chainId\":$bchainId,\"balance\":\"$bal_val\",\"token\":\"$token_symbol\"}"
        else
            if [ "$bal_val" != "0" ] && [ "$bal_val" != "0.0" ]; then
                printf "  ${GREEN}%-18s${NC} %16s\n" "$bchain" "$bal_val"
            else
                printf "  %-18s %16s\n" "$bchain" "$bal_val"
            fi
        fi
    done < <(sort -t'|' -k1,1 -rn "$tmpfile")

    json_results+="]"
    rm -f "$tmpfile"

    if [ "$JSON_OUTPUT" = "true" ]; then
        echo "$json_results" | "$JQ" .
    else
        echo ""
    fi
}

# --- suggest ---

cmd_suggest() {
    local addr="${1:-}"
    if [ -z "$addr" ]; then
        echo "Usage: $0 suggest <address>"; exit 1
    fi

    echo ""
    echo "========================================================="
    echo "|  Portfolio Suggestions                                 |"
    echo "+---------------------------------------------------------+"
    printf "|  Address: %-42s  |\n" "${addr:0:42}"
    echo "========================================================="
    echo ""

    # 1. Collect token balances across all chains
    local tmpfile; tmpfile=$(mktemp)
    while IFS='|' read -r chain rpc chainId nativeToken ctype; do
        if [ "$ctype" = "solana" ]; then continue; fi

        local native_bal=0
        if command -v cast >/dev/null 2>&1; then
            native_bal=$(cast balance "$addr" --rpc-url "$rpc" --ether 2>/dev/null) || native_bal=0
        else
            local resp
            resp=$(curl -s -X POST -H "Content-Type: application/json" \
                --data "{\"jsonrpc\":\"2.0\",\"method\":\"eth_getBalance\",\"params\":[\"$addr\",\"latest\"],\"id\":1}" \
                --connect-timeout 5 --max-time 10 "$rpc" 2>/dev/null) || true
            local wei_hex
            wei_hex=$(echo "$resp" | "$JQ" -r '.result // "0x0"' 2>/dev/null)
            native_bal=$($PY -c "print(round(int('$wei_hex', 16) / 1e18, 6))" 2>/dev/null || echo "0")
        fi
        echo "NATIVE|$chain|$nativeToken|$native_bal|$chainId|$rpc" >> "$tmpfile"

        # Check USDC for this chain
        local usdc_addr
        usdc_addr=$("$JQ" -r --arg ch "$chain" '.[$ch] // [] | .[] | select(.symbol == "USDC") | .address' "$TOKENS_FILE" 2>/dev/null | head -1)
        if [ -n "$usdc_addr" ] && [ "$usdc_addr" != "null" ]; then
            local raw
            if command -v cast >/dev/null 2>&1; then
                raw=$(cast call "$usdc_addr" "balanceOf(address)(uint256)" "$addr" --rpc-url "$rpc" 2>/dev/null) || raw="0x0"
            else
                raw="0x0"
            fi
            local bal
            bal=$($PY -c "print(round(int('$raw', 16) / 1e6, 4))" 2>/dev/null || echo "0")
            echo "USDC|$chain|$bal|$rpc" >> "$tmpfile"
        fi
    done < <(get_rpcs)

    # 2. Check gas prices across chains
    local gas_file; gas_file=$(mktemp)
    while IFS='|' read -r chain rpc chainId nativeToken ctype; do
        if [ "$ctype" = "solana" ]; then continue; fi
        local resp gas_hex gas_gwei
        resp=$(curl -s -X POST -H "Content-Type: application/json" \
            --data '{"jsonrpc":"2.0","method":"eth_gasPrice","params":[],"id":1}' \
            --connect-timeout 5 --max-time 10 "$rpc" 2>/dev/null) || true
        gas_hex=$(echo "$resp" | "$JQ" -r '.result // "0x0"' 2>/dev/null)
        if [ -n "$gas_hex" ] && [ "$gas_hex" != "0x0" ]; then
            local gwei
            gwei=$($PY -c "print(round(int('$gas_hex', 16) / 1e9, 2))" 2>/dev/null || echo "999")
            echo "$gwei|$chain|$rpc" >> "$gas_file"
        fi
    done < <(get_rpcs)

    # 3. Generate suggestions
    local suggestions=0

    # Suggestion A: Where to bridge from
    local best_usdc_chain best_usdc_bal=0
    while IFS='|' read -r token chain bal rpc; do
        [ "$token" != "USDC" ] && continue
        local is_gt; is_gt=$($PY -c "print(1 if float($bal) > float($best_usdc_bal) else 0)" 2>/dev/null || echo "0")
        if [ "$is_gt" = "1" ]; then
            best_usdc_chain="$chain"; best_usdc_bal="$bal"
        fi
    done < "$tmpfile"

    if [ "$best_usdc_bal" != "0" ] && [ "$best_usdc_bal" != "0.0" ]; then
        echo "  [BRIDGE] You have $best_usdc_bal USDC on $best_usdc_chain."
        # Find cheapest gas chain to bridge to
        local cheapest_gas_chain cheapest_gas=999
        while IFS='|' read -r gwei chain rpc; do
            local is_lt; is_lt=$($PY -c "print(1 if float($gwei) < float($cheapest_gas) else 0)" 2>/dev/null || echo "0")
            if [ "$is_lt" = "1" ] && [ "$chain" != "$best_usdc_chain" ]; then
                cheapest_gas="$gwei"; cheapest_gas_chain="$chain"
            fi
        done < <(sort -t'|' -k1,1 -n "$gas_file")
        if [ -n "$cheapest_gas_chain" ] && [ "$cheapest_gas_chain" != "$best_usdc_chain" ]; then
            echo "  -> Bridge to $cheapest_gas_chain (${cheapest_gas} gwei vs $best_usdc_chain gas)"
        fi
        echo ""
        suggestions=$((suggestions + 1))
    fi

    # Suggestion B: Cheapest chain for transactions
    local cheapest; cheapest=$(sort -t'|' -k1,1 -n "$gas_file" | head -1)
    local cheap_gwei cheap_chain; cheap_chain=$(echo "$cheapest" | cut -d'|' -f2); cheap_gwei=$(echo "$cheapest" | cut -d'|' -f1)
    echo "  [GAS] Cheapest chain for transactions: $cheap_chain at ${cheap_gwei} gwei"
    suggestions=$((suggestions + 1))

    # Suggestion C: Where to deploy contracts (lowest gas)
    local deploy_chain=$(sort -t'|' -k1,1 -n "$gas_file" | head -3 | tail -1 | cut -d'|' -f2)
    local deploy_gwei=$(sort -t'|' -k1,1 -n "$gas_file" | head -3 | tail -1 | cut -d'|' -f1)
    echo "  [DEPLOY] Best chain to deploy contracts: $deploy_chain (${deploy_gwei} gwei)"
    suggestions=$((suggestions + 1))

    # Suggestion D: Where you have gas to pay
    echo ""
    echo "  [GAS BALANCE] Chains where you can pay for tx:"
    local gas_found=0
    while IFS='|' read -r type chain token bal cid rpc; do
        [ "$type" != "NATIVE" ] && continue
        local is_gt; is_gt=$($PY -c "print(1 if float($bal) > 0 else 0)" 2>/dev/null || echo "0")
        if [ "$is_gt" = "1" ]; then
            printf "    %-18s %12s %s\n" "$chain" "$bal" "$token"
            gas_found=$((gas_found + 1))
        fi
    done < "$tmpfile"
    [ "$gas_found" -eq 0 ] && echo "    (none - fund a wallet first)"

    echo ""
    echo "  $suggestions suggestions generated."

    rm -f "$tmpfile" "$gas_file"
}

# --- dispatch ---

# Parse global flags
ARGS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --json) JSON_OUTPUT=true; shift;;
        --csv)  CSV_MODE=true; JSON_OUTPUT=true; shift;;
        --usd|--dollar) USD_MODE=true; shift;;
        --quiet|-q) QUIET_MODE=true; shift;;
        --all) ALL_CHAINS=true; shift;;
        *) ARGS+=("$1"); shift;;
    esac
done
set -- "${ARGS[@]}"

case "${1:-help}" in
    balance|bal)   shift; cmd_balance "$@";;
    tx|find)       shift; cmd_tx "$@";;
    portfolio|port|pf) shift; cmd_portfolio "$@";;
    label|lab|who) shift; cmd_label "$@";;
    verify|ver)    shift; cmd_verify "$@";;
    health|ping|status) shift; cmd_health "$@";;
    gas|price)     shift; cmd_gas "$@";;
    top|rank)      shift; cmd_top "$@";;
    suggest|rec)   shift; cmd_suggest "$@";;
    help|--help|-h)
        echo "Usage: $0 <command> [args...] [--json]"
        echo ""
        echo "Commands:"
        echo "  balance|bal  <address> [chain]    Multi-chain native balance"
        echo "  tx|find      <tx-hash>            Cross-chain tx lookup"
        echo "  portfolio|port|pf <address> [ch]  Full token portfolio across chains"
        echo "  label|lab|who <address>           Address label lookup"
        echo "  verify|ver   <address> [chain]    Contract verification check"
        echo "  health|ping|status [chain]        RPC health check across all chains"
        echo "  gas|price    [chain]              Compare gas prices across chains"
        echo "  top|rank     <addr> [token]       Rank chains by token balance"
        echo ""
        echo "Flags:"
        echo "  --json          Machine-readable JSON output (for agent consumption)"
        echo "  --usd|--dollar  Show estimated USD value alongside balances"
        echo "  --all           Query ALL configured chains (default: top 15 only)"
        echo "  --quiet|-q      Suppress banners and formatting"
        echo ""
        echo "Aliases: bal=balance, port=portfolio, lab=label, ver=verify"
        echo ""
        echo "Examples:"
        echo "  $0 bal 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045"
        echo "  $0 port 0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266"
        echo "  $0 health --json"
        echo "  $0 label 0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045"
        ;;
    *)
        echo "Unknown command: $1"
        echo "Run '$0 help' for usage."
        exit 1
        ;;
esac
